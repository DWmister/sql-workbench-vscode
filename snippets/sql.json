{
  "Select statement": {
    "prefix": "sel",
    "body": [
      "SELECT ${1:*}",
      "FROM ${2:table_name}",
      "WHERE ${3:condition}",
      "LIMIT ${4:100};"
    ],
    "description": "SELECT statement with LIMIT"
  },
  "Insert statement": {
    "prefix": "ins",
    "body": [
      "INSERT INTO ${1:table_name} (${2:columns})",
      "VALUES (${3:values});"
    ],
    "description": "INSERT statement"
  },
  "Update statement": {
    "prefix": "upd",
    "body": [
      "UPDATE ${1:table_name}",
      "SET ${2:column} = ${3:value}",
      "WHERE ${4:condition};"
    ],
    "description": "UPDATE statement with WHERE"
  },
  "Delete statement": {
    "prefix": "del",
    "body": [
      "DELETE FROM ${1:table_name}",
      "WHERE ${2:condition};"
    ],
    "description": "DELETE statement with WHERE"
  },
  "Join clause": {
    "prefix": "joi",
    "body": [
      "JOIN ${1:table_name} ${2:alias} ON ${3:condition}"
    ],
    "description": "JOIN clause"
  },
  "Distinct expression": {
    "prefix": "dis",
    "body": [
      "DISTINCT ${1:column}"
    ],
    "description": "DISTINCT expression"
  },
  "Order by clause": {
    "prefix": "ord",
    "body": [
      "ORDER BY ${1:column} ${2:DESC}"
    ],
    "description": "ORDER BY clause"
  },
  "Case when expression": {
    "prefix": "cas",
    "body": [
      "CASE",
      "  WHEN ${1:condition} THEN ${2:value}",
      "  ELSE ${3:value}",
      "END"
    ],
    "description": "CASE WHEN expression"
  },
  "Coalesce expression": {
    "prefix": "coa",
    "body": [
      "COALESCE(${1:value}, ${2:fallback})"
    ],
    "description": "COALESCE expression"
  },
  "Date format expression": {
    "prefix": "dat",
    "body": [
      "DATE_FORMAT(${1:date}, '${2:%Y-%m-%d}')"
    ],
    "description": "DATE_FORMAT expression"
  }
}
